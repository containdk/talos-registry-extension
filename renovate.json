{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>containdk/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Makefile$/"
      ],
      "matchStrings": [
        "TALOS_VERSION \\?= (?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases"
    }
  ]
}
